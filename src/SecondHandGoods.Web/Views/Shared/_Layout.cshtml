<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" id="themeColorMeta" />
    <script>
        (function () {
            try {
                var t = localStorage.getItem('theme');
                if (t !== 'dark' && t !== 'light') t = 'light';
                document.documentElement.setAttribute('data-theme', t);
                var m = document.getElementById('themeColorMeta');
                if (m) m.setAttribute('content', t === 'dark' ? '#1a1a1a' : '#ffffff');
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <style>
        html[data-theme="dark"],
        html[data-theme="dark"] body {
            background-color: #1a1a1a !important;
            color: #e0e0e0 !important;
        }
        html[data-theme="dark"] { color-scheme: dark; }
        html[data-theme="light"] { color-scheme: light; }
    </style>
    <title>@ViewData["Title"] - GreenSwap</title>
    <link rel="icon" type="image/png" href="~/images/greenswap-logo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/greenswap-logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SecondHandGoods.Web.styles.css" asp-append-version="true" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2 py-1" asp-area="" asp-controller="Home" asp-action="Index" title="GreenSwap home">
                    <img src="~/images/greenswap-logo.png" alt="" width="40" height="40" class="site-navbar-logo flex-shrink-0" asp-append-version="true" />
                    <span class="fw-semibold">GreenSwap</span>
                </a>
                <div class="d-flex align-items-center gap-2 ms-auto flex-shrink-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm d-lg-none js-theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                        <i class="fas fa-moon js-theme-icon"></i>
                    </button>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbarCollapse" aria-controls="mainNavbarCollapse"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="navbar-collapse collapse" id="mainNavbarCollapse">
                    <div class="d-lg-none w-100 px-2 pt-2 pb-2 border-bottom">
                        <form asp-controller="Ads" asp-action="Index" method="get" class="d-flex gap-2">
                            <input name="searchTerm" type="search" class="form-control form-control-sm flex-grow-1" placeholder="Search listings..." aria-label="Search" />
                            <button class="btn btn-outline-primary btn-sm flex-shrink-0" type="submit" title="Search">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </div>
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 flex-lg-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-shopping-bag me-1"></i>Browse
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Ads" asp-action="Index">
                                        <i class="fas fa-list me-2"></i>All Items
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">
                                        <i class="fas fa-th-large me-2"></i>Categories
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Popular Categories</h6></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="1">
                                        <i class="fas fa-laptop me-2"></i>Electronics
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="2">
                                        <i class="fas fa-car me-2"></i>Vehicles
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="3">
                                        <i class="fas fa-home me-2"></i>Home & Garden
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Search" asp-action="Advanced">
                                        <i class="fas fa-search-plus me-2"></i>Advanced Search
                                    </a></li>
                                </ul>
                            </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Ads" asp-action="Create">
                                    <i class="fas fa-plus me-1"></i>Post Ad
                                </a>
                            </li>
                        }
                        </ul>

                        <!-- Desktop: quick search + theme (lg+) -->
                        <div class="d-none d-lg-flex align-items-center gap-2 me-3 flex-shrink-0">
                            <form asp-controller="Ads" asp-action="Index" method="get" class="d-flex">
                                <input name="searchTerm" type="search" class="form-control form-control-sm me-2"
                                       placeholder="Quick search..." aria-label="Search" style="min-width: 180px; max-width: 280px;">
                                <button class="btn btn-outline-primary btn-sm" type="submit" title="Search">
                                    <i class="fas fa-search"></i>
                                </button>
                            </form>
                            <button type="button" class="btn btn-outline-secondary btn-sm js-theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                                <i class="fas fa-moon js-theme-icon"></i>
                            </button>
                        </div>

                        <ul class="navbar-nav mb-2 mb-lg-0 ms-lg-auto">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark position-relative pe-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user me-1"></i>@User.Identity!.Name
                                    <span id="navProfileUnreadBadge" class="badge rounded-pill bg-danger nav-profile-unread-badge" style="display: none;" aria-hidden="true"></span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user-edit me-2"></i>Profile
                                    </a></li>
                                        <li><a class="dropdown-item" asp-controller="Ads" asp-action="MyAds">
                                            <i class="fas fa-user-tag me-2"></i>My Ads
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Ads" asp-action="Favorites">
                                            <i class="fas fa-heart me-2"></i>Favorites
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Chat" asp-action="Index">
                                            <i class="fas fa-comments me-2"></i>Messages
                                            <span id="navUnreadBadge" class="badge bg-danger ms-1" style="display: none;"></span>
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Reviews" asp-action="Pending">
                                            <i class="fas fa-star me-2"></i>Reviews
                                            <span id="navPendingReviewsBadge" class="badge bg-warning text-dark ms-1" style="display: none;"></span>
                                        </a></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                            <i class="fas fa-cog me-2"></i>Admin Panel
                                        </a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus me-1"></i>Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <!-- Admin Navigation Bar (only shown on admin pages); collapses below lg -->
    @if (ViewData["ShowAdminNavigation"] != null && (bool)ViewData["ShowAdminNavigation"] && User.IsInRole("Admin"))
    {
        <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-2">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 text-white" style="font-size: 1rem;">
                    <i class="fas fa-shield-alt me-2"></i>Administration
                </span>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbarCollapse"
                        aria-controls="adminNavbarCollapse" aria-expanded="false" aria-label="Toggle admin navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNavbarCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 flex-column flex-lg-row flex-wrap gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")"
                               asp-controller="Admin" asp-action="Users">
                                <i class="fas fa-users me-1"></i>Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Advertisements" ? "active" : "")"
                               asp-controller="Admin" asp-action="Advertisements">
                                <i class="fas fa-tags me-1"></i>Advertisements
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Statistics" ? "active" : "")"
                               asp-controller="Admin" asp-action="Statistics">
                                <i class="fas fa-chart-bar me-1"></i>Statistics
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Moderation" || ViewContext.RouteData.Values["Action"]?.ToString() == "ForbiddenWords" ? "active" : "")"
                               asp-controller="Admin" asp-action="Moderation">
                                <i class="fas fa-shield-alt me-1"></i>Moderation
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SiteAds" || ViewContext.RouteData.Values["Action"]?.ToString() == "EditSiteAd" ? "active" : "")"
                               asp-controller="Admin" asp-action="SiteAds">
                                <i class="fas fa-ad me-1"></i>Site Ads
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 flex-column flex-lg-row align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <span class="navbar-text px-lg-1">
                                <i class="fas fa-user-shield me-1"></i>Admin: @User.Identity!.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-arrow-left me-1"></i>Exit Admin
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Pre-footer: featured listings + paid ads (separate sections; see _FooterContent / _FeaturedListingsSection / _PaidAdsSection) -->
    @await Html.PartialAsync("_FooterContent")

    <footer class="site-footer border-top">
        <div class="container py-4 py-lg-5">
            <div class="row g-4 align-items-start">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <img src="~/images/greenswap-logo.png" alt="" width="36" height="36" class="rounded-2 flex-shrink-0" asp-append-version="true" />
                        <span class="fw-semibold text-body">GreenSwap</span>
                    </div>
                    <p class="small text-muted mb-2 footer-tagline">
                        Your local marketplace for pre-owned items.<br />
                        Buy, sell, and chat with confidence—<br />
                        built for real neighborhoods, not warehouses.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-muted" title="Placeholder" aria-label="Social placeholder"><i class="fab fa-facebook-f fa-lg"></i></a>
                        <a href="#" class="text-muted" title="Placeholder" aria-label="Social placeholder"><i class="fab fa-twitter fa-lg"></i></a>
                        <a href="#" class="text-muted" title="Placeholder" aria-label="Social placeholder"><i class="fab fa-instagram fa-lg"></i></a>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-2">
                    <p class="footer-col-title text-uppercase fw-bold">Browse</p>
                    <ul class="list-unstyled small mb-0 footer-link-list">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Ads" asp-action="Index">All listings</a></li>
                        <li><a asp-controller="Categories" asp-action="Index">Categories</a></li>
                        <li><a asp-controller="Search" asp-action="Advanced">Advanced search</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md-4 col-lg-2">
                    <p class="footer-col-title text-uppercase fw-bold">Account</p>
                    <ul class="list-unstyled small mb-0 footer-link-list">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li><a asp-controller="Ads" asp-action="Create">Post an ad</a></li>
                            <li><a asp-controller="Ads" asp-action="MyAds">My ads</a></li>
                            <li><a asp-controller="Chat" asp-action="Index">Messages</a></li>
                            <li><a asp-controller="Account" asp-action="Profile">Profile</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Account" asp-action="Login">Log in</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
                <div class="col-md-4 col-lg-4">
                    <p class="footer-col-title text-uppercase fw-bold">Contact</p>
                    <ul class="list-unstyled small mb-0 footer-contact-list">
                        <li class="d-flex align-items-start gap-2">
                            <i class="fas fa-phone mt-1 text-success flex-shrink-0" aria-hidden="true"></i>
                            <span class="d-block">
                                <a href="tel:+15550123456" class="fw-medium d-inline-block">(555) 012-3456</a>
                                <span class="d-block text-muted small lh-sm">Mon–Fri 9:00–17:00</span>
                            </span>
                        </li>
                        <li class="d-flex align-items-start gap-2">
                            <i class="fas fa-envelope mt-1 text-success flex-shrink-0" aria-hidden="true"></i>
                            <a href="mailto:support@greenswap.example">support@greenswap.example</a>
                        </li>
                        <li class="d-flex align-items-start gap-2">
                            <i class="fas fa-location-dot mt-1 text-success flex-shrink-0" aria-hidden="true"></i>
                            <span class="text-muted lh-sm">100 Market Street, Suite 400<br />San Francisco, CA 94105</span>
                        </li>
                    </ul>
                </div>
            </div>
            <hr class="my-4 border-secondary opacity-25" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 small text-muted">
                <span>&copy; @DateTime.UtcNow.Year GreenSwap. All rights reserved.</span>
                <div class="d-flex flex-wrap gap-3 justify-content-center">
                    <a asp-controller="Home" asp-action="Privacy" class="text-muted">Privacy</a>
                    <a asp-controller="Home" asp-action="Terms" class="text-muted">Terms</a>
                    <a asp-controller="Home" asp-action="Help" class="text-muted">Help</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Dark Mode Toggle Script (theme is already applied in &lt;head&gt; to avoid flash) -->
    <script>
        (function() {
            const themeColorMeta = document.getElementById('themeColorMeta');
            const html = document.documentElement;
            const currentTheme = localStorage.getItem('theme') || 'light';
            function setThemeColorMeta(theme) {
                if (themeColorMeta) themeColorMeta.setAttribute('content', theme === 'dark' ? '#1a1a1a' : '#ffffff');
            }
            function updateThemeIcons(theme) {
                var icon = theme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
                document.querySelectorAll('.js-theme-icon').forEach(function (el) {
                    el.className = icon + ' js-theme-icon';
                });
            }
            updateThemeIcons(currentTheme);
            setThemeColorMeta(currentTheme);
            function toggleTheme() {
                var t = html.getAttribute('data-theme') || 'light';
                var newTheme = t === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateThemeIcons(newTheme);
                setThemeColorMeta(newTheme);
            }
            document.querySelectorAll('.js-theme-toggle').forEach(function (btn) {
                btn.addEventListener('click', toggleTheme);
            });
        })();
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
