<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" id="themeColorMeta" />
    <script>
        (function () {
            try {
                var t = localStorage.getItem('theme');
                if (t !== 'dark' && t !== 'light') t = 'light';
                document.documentElement.setAttribute('data-theme', t);
                var m = document.getElementById('themeColorMeta');
                if (m) m.setAttribute('content', t === 'dark' ? '#1a1a1a' : '#ffffff');
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <style>
        html[data-theme="dark"],
        html[data-theme="dark"] body {
            background-color: #1a1a1a !important;
            color: #e0e0e0 !important;
        }
        html[data-theme="dark"] { color-scheme: dark; }
        html[data-theme="light"] { color-scheme: light; }
    </style>
    <title>@ViewData["Title"] - GreenSwap</title>
    <link rel="icon" type="image/png" href="~/images/greenswap-logo.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/greenswap-logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SecondHandGoods.Web.styles.css" asp-append-version="true" />
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2 py-1" asp-area="" asp-controller="Home" asp-action="Index" title="GreenSwap home">
                    <img src="~/images/greenswap-logo.png" alt="" width="40" height="40" class="site-navbar-logo flex-shrink-0" asp-append-version="true" />
                    <span class="fw-semibold">GreenSwap</span>
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm d-lg-none js-theme-toggle ms-auto me-2" title="Toggle dark mode" aria-label="Toggle dark mode">
                    <i class="fas fa-moon js-theme-icon"></i>
                </button>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbarCollapse" aria-controls="mainNavbarCollapse"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNavbarCollapse">
                    <div class="d-lg-none w-100 px-2 pt-2 pb-2 border-bottom">
                        <form asp-controller="Ads" asp-action="Index" method="get" class="d-flex gap-2">
                            <input name="searchTerm" type="search" class="form-control form-control-sm flex-grow-1" placeholder="Search listings..." aria-label="Search" />
                            <button class="btn btn-outline-primary btn-sm flex-shrink-0" type="submit" title="Search">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </div>
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" role="button" 
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-shopping-bag me-1"></i>Browse
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Ads" asp-action="Index">
                                        <i class="fas fa-list me-2"></i>All Items
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">
                                        <i class="fas fa-th-large me-2"></i>Categories
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Popular Categories</h6></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="1">
                                        <i class="fas fa-laptop me-2"></i>Electronics
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="2">
                                        <i class="fas fa-car me-2"></i>Vehicles
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Browse" asp-route-id="3">
                                        <i class="fas fa-home me-2"></i>Home & Garden
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Search" asp-action="Advanced">
                                        <i class="fas fa-search-plus me-2"></i>Advanced Search
                                    </a></li>
                                </ul>
                            </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Ads" asp-action="Create">
                                    <i class="fas fa-plus me-1"></i>Post Ad
                                </a>
                            </li>
                        }
                        </ul>

                        <!-- Desktop: quick search + theme (lg+) -->
                        <div class="d-none d-lg-flex align-items-center gap-2 me-3 flex-shrink-0">
                            <form asp-controller="Ads" asp-action="Index" method="get" class="d-flex">
                                <input name="searchTerm" type="search" class="form-control form-control-sm me-2"
                                       placeholder="Quick search..." aria-label="Search" style="min-width: 180px; max-width: 280px;">
                                <button class="btn btn-outline-primary btn-sm" type="submit" title="Search">
                                    <i class="fas fa-search"></i>
                                </button>
                            </form>
                            <button type="button" class="btn btn-outline-secondary btn-sm js-theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                                <i class="fas fa-moon js-theme-icon"></i>
                            </button>
                        </div>

                        <ul class="navbar-nav mb-2 mb-lg-0">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user me-1"></i>@User.Identity!.Name
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user-edit me-2"></i>Profile
                                    </a></li>
                                        <li><a class="dropdown-item" asp-controller="Ads" asp-action="MyAds">
                                            <i class="fas fa-user-tag me-2"></i>My Ads
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Chat" asp-action="Index">
                                            <i class="fas fa-comments me-2"></i>Messages
                                            <span id="navUnreadBadge" class="badge bg-danger ms-1" style="display: none;"></span>
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Reviews" asp-action="Pending">
                                            <i class="fas fa-star me-2"></i>Reviews
                                            <span id="navPendingReviewsBadge" class="badge bg-warning text-dark ms-1" style="display: none;"></span>
                                        </a></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                            <i class="fas fa-cog me-2"></i>Admin Panel
                                        </a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus me-1"></i>Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <!-- Admin Navigation Bar (only shown on admin pages) -->
    @if (ViewData["ShowAdminNavigation"] != null && (bool)ViewData["ShowAdminNavigation"] && User.IsInRole("Admin"))
    {
        <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-2">
            <div class="container-fluid">
                <div class="navbar-nav">
                    <a class="navbar-brand me-4" href="#" style="font-size: 1rem;">
                        <i class="fas fa-shield-alt me-2"></i>Administration
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" 
                       asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")" 
                       asp-controller="Admin" asp-action="Users">
                        <i class="fas fa-users me-1"></i>Users
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Advertisements" ? "active" : "")" 
                       asp-controller="Admin" asp-action="Advertisements">
                        <i class="fas fa-tags me-1"></i>Advertisements
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Statistics" ? "active" : "")" 
                       asp-controller="Admin" asp-action="Statistics">
                        <i class="fas fa-chart-bar me-1"></i>Statistics
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Moderation" || ViewContext.RouteData.Values["Action"]?.ToString() == "ForbiddenWords" ? "active" : "")" 
                       asp-controller="Admin" asp-action="Moderation">
                        <i class="fas fa-shield-alt me-1"></i>Moderation
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SiteAds" || ViewContext.RouteData.Values["Action"]?.ToString() == "EditSiteAd" ? "active" : "")" 
                       asp-controller="Admin" asp-action="SiteAds">
                        <i class="fas fa-ad me-1"></i>Site Ads
                    </a>
                </div>
                <div class="navbar-nav ms-auto">
                    <span class="navbar-text me-3">
                        <i class="fas fa-user-shield me-1"></i>Admin: @User.Identity!.Name
                    </span>
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-arrow-left me-1"></i>Exit Admin
                    </a>
                </div>
            </div>
        </nav>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer Content: User Ads Carousel and Paid Ads -->
    @await Html.PartialAsync("_FooterContent")

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GreenSwap
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Dark Mode Toggle Script (theme is already applied in &lt;head&gt; to avoid flash) -->
    <script>
        (function() {
            const themeColorMeta = document.getElementById('themeColorMeta');
            const html = document.documentElement;
            const currentTheme = localStorage.getItem('theme') || 'light';
            function setThemeColorMeta(theme) {
                if (themeColorMeta) themeColorMeta.setAttribute('content', theme === 'dark' ? '#1a1a1a' : '#ffffff');
            }
            function updateThemeIcons(theme) {
                var icon = theme === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
                document.querySelectorAll('.js-theme-icon').forEach(function (el) {
                    el.className = icon + ' js-theme-icon';
                });
            }
            updateThemeIcons(currentTheme);
            setThemeColorMeta(currentTheme);
            function toggleTheme() {
                var t = html.getAttribute('data-theme') || 'light';
                var newTheme = t === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateThemeIcons(newTheme);
                setThemeColorMeta(newTheme);
            }
            document.querySelectorAll('.js-theme-toggle').forEach(function (btn) {
                btn.addEventListener('click', toggleTheme);
            });
        })();
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
