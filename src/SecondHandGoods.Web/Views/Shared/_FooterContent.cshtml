<!-- Footer Content: User Ads Carousel and Paid Ad Spaces -->
<div class="footer-content-section py-4 mt-5">
    <div class="container">
        <!-- User Ads Carousel Section -->
        @await Component.InvokeAsync("FeaturedAds")

        <!-- Paid Advertisement Spaces (from DB: footer-1, footer-2, footer-3) -->
        <div class="row">
            <div class="col-12">
                <div class="border-top pt-3">
                    @await Component.InvokeAsync("PaidAds")
                </div>
            </div>
        </div>
    </div>
</div>

