@model SecondHandGoods.Web.Models.Chat.ConversationListViewModel
@{
    ViewData["Title"] = "Messages";
}

<div class="container">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-stretch align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="display-6 mb-2">
                <i class="fas fa-comments text-primary me-3"></i>Messages
            </h1>
            <p class="text-muted">
                Manage your conversations with buyers and sellers
            </p>
        </div>
        <div class="align-self-md-end">
            @if (Model.TotalUnreadCount > 0)
            {
                <span class="badge bg-danger fs-6">
                    @Model.TotalUnreadCount unread message@(Model.TotalUnreadCount == 1 ? "" : "s")
                </span>
            }
        </div>
    </div>

    @if (Model.Conversations.Any())
    {
        <!-- Conversations List -->
        <div class="card shadow-sm">
            <div class="card-body p-0">
                @foreach (var conversation in Model.Conversations)
                {
                    <div class="@conversation.ConversationClasses border-bottom p-3">
                        <div class="row align-items-center">
                            <!-- Advertisement Image -->
                            <div class="col-auto">
                                <img src="@conversation.AdvertisementImageUrl" 
                                     alt="@conversation.AdvertisementTitle" 
                                     class="rounded"
                                     style="width: 60px; height: 60px; object-fit: cover;" />
                            </div>

                            <!-- Conversation Details -->
                            <div class="col">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="mb-1">
                                            <a asp-action="Conversation" 
                                               asp-route-advertisementId="@conversation.AdvertisementId"
                                               asp-route-otherUserId="@conversation.OtherUserId"
                                               class="text-decoration-none text-dark">
                                                @conversation.AdvertisementTitle
                                            </a>
                                            @if (!string.IsNullOrEmpty(conversation.StatusBadgeText))
                                            {
                                                <span class="@conversation.StatusBadgeClass ms-2">
                                                    @conversation.StatusBadgeText
                                                </span>
                                            }
                                        </h6>
                                        <p class="text-muted mb-1 small">
                                            <i class="fas fa-user me-1"></i>@conversation.OtherUserName
                                            @if (conversation.OtherUserRating > 0)
                                            {
                                                <span class="ms-2">
                                                    <i class="fas fa-star text-warning"></i>@conversation.OtherUserRating.ToString("F1")
                                                </span>
                                            }
                                            @if (conversation.IsOtherUserOnline)
                                            {
                                                <span class="badge bg-success ms-2">Online</span>
                                            }
                                        </p>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-primary fw-bold mb-1">@conversation.FormattedPrice</div>
                                        <small class="text-muted">@conversation.LastMessageTimeAgo</small>
                                    </div>
                                </div>

                                <!-- Last Message -->
                                <div class="d-flex justify-content-between align-items-center">
                                    <p class="mb-0 small @(conversation.LastMessageFromCurrentUser ? "text-muted" : "")">
                                        @if (conversation.LastMessageFromCurrentUser)
                                        {
                                            <i class="fas fa-reply me-1"></i><span class="fw-bold">You:</span>
                                        }
                                        @conversation.TruncatedLastMessage
                                    </p>
                                    @if (conversation.UnreadCount > 0)
                                    {
                                        <span class="badge bg-primary">@conversation.UnreadCount</span>
                                    }
                                </div>
                            </div>

                            <!-- Action Dropdown -->
                            <div class="col-auto">
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                            type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" 
                                               asp-action="Conversation" 
                                               asp-route-advertisementId="@conversation.AdvertisementId"
                                               asp-route-otherUserId="@conversation.OtherUserId">
                                                <i class="fas fa-eye me-2"></i>View Conversation
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" 
                                               asp-controller="Ads" asp-action="Details" 
                                               asp-route-id="@conversation.AdvertisementId">
                                                <i class="fas fa-external-link-alt me-2"></i>View Ad
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="DeleteConversation" method="post" class="d-inline">
                                                <input type="hidden" name="advertisementId" value="@conversation.AdvertisementId" />
                                                <input type="hidden" name="otherUserId" value="@conversation.OtherUserId" />
                                                <button type="submit" class="dropdown-item text-danger"
                                                        onclick="return confirm('Are you sure you want to delete this conversation? This action cannot be undone.');">
                                                    <i class="fas fa-trash me-2"></i>Delete Conversation
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Conversations pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.HasPrevious ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <!-- Empty State -->
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fas fa-comments fa-4x text-muted mb-4"></i>
                <h5 class="text-muted mb-3">No conversations yet</h5>
                <p class="text-muted mb-4">
                    Start browsing items and contact sellers to begin conversations.
                </p>
                <a asp-controller="Ads" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-search me-1"></i>Browse Items
                </a>
            </div>
        </div>
    }

    <!-- Statistics -->
    @if (Model.Conversations.Any())
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card bg-light border-0">
                    <div class="card-body text-center">
                        <div class="row">
                            <div class="col-4">
                                <h6 class="text-primary mb-1">@Model.TotalConversations</h6>
                                <small class="text-muted">Total Conversations</small>
                            </div>
                            <div class="col-4">
                                <h6 class="text-danger mb-1">@Model.TotalUnreadCount</h6>
                                <small class="text-muted">Unread Messages</small>
                            </div>
                            <div class="col-4">
                                <h6 class="text-success mb-1">@(Model.TotalConversations - Model.TotalUnreadCount)</h6>
                                <small class="text-muted">Read Conversations</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .conversation-item {
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .conversation-item:hover {
        background-color: #f8f9fa;
    }

    .conversation-unread {
        background-color: #fff3cd !important;
        border-left: 4px solid #ffc107 !important;
    }

    .conversation-unread:hover {
        background-color: #fff2a8 !important;
    }

    .conversation-item:last-child {
        border-bottom: none !important;
    }
</style>

@section Scripts {
    <script>
        // Auto-refresh unread count every 30 seconds
        setInterval(async function() {
            try {
                const response = await fetch('/Chat/UnreadCount');
                const data = await response.json();
                
                // Update navbar badge if it exists
                const navBadge = document.querySelector('.navbar .badge');
                if (navBadge && data.unreadCount > 0) {
                    navBadge.textContent = data.unreadCount;
                    navBadge.style.display = 'inline-block';
                } else if (navBadge) {
                    navBadge.style.display = 'none';
                }
            } catch (error) {
                console.error('Error updating unread count:', error);
            }
        }, 30000);

        // Add click handlers for conversation items
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.conversation-item').forEach(item => {
                item.addEventListener('click', function(e) {
                    // Don't navigate if clicking on dropdown or form elements
                    if (!e.target.closest('.dropdown') && !e.target.closest('form')) {
                        const conversationLink = this.querySelector('a[href*="Conversation"]');
                        if (conversationLink) {
                            window.location.href = conversationLink.href;
                        }
                    }
                });
            });
        });
    </script>
}