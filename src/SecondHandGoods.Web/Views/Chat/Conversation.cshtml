@model SecondHandGoods.Web.Models.Chat.ConversationViewModel
@{
    ViewData["Title"] = $"Chat about {Model.AdvertisementTitle}";
}

<div class="container-fluid h-100">
    <div class="row h-100">
        <!-- Conversation Header -->
        <div class="col-12">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <!-- Advertisement Info -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <img src="@Model.AdvertisementImageUrl" 
                                     alt="@Model.AdvertisementTitle" 
                                     class="rounded me-3"
                                     style="width: 60px; height: 60px; object-fit: cover;" />
                                <div>
                                    <h6 class="mb-1">
                                        <a asp-controller="Ads" asp-action="Details" asp-route-id="@Model.AdvertisementId"
                                           class="text-decoration-none">
                                            @Model.AdvertisementTitle
                                        </a>
                                        @if (Model.IsAdvertisementSold)
                                        {
                                            <span class="badge bg-success ms-2">SOLD</span>
                                        }
                                        else if (!Model.IsAdvertisementActive)
                                        {
                                            <span class="badge bg-secondary ms-2">INACTIVE</span>
                                        }
                                    </h6>
                                    <div class="text-primary fw-bold">@Model.FormattedPrice</div>
                                    @if (!string.IsNullOrEmpty(Model.AdvertisementLocation))
                                    {
                                        <small class="text-muted">
                                            <i class="fas fa-map-marker-alt me-1"></i>@Model.AdvertisementLocation
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Chat Partner Info -->
                        <div class="col-md-4">
                            <div class="text-center">
                                <h6 class="mb-1">
                                    <i class="fas fa-user me-2"></i>@Model.OtherUserName
                                    <span id="userOnlineStatus" class="badge bg-secondary ms-2" style="display: none;">Online</span>
                                </h6>
                                @if (Model.OtherUserRating > 0)
                                {
                                    <div class="mb-1">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fas fa-star @(i <= Model.OtherUserRating ? "text-warning" : "text-muted")"></i>
                                        }
                                        <span class="small text-muted">(@Model.OtherUserRating.ToString("F1"))</span>
                                    </div>
                                }
                                <small class="text-muted">Joined @Model.OtherUserJoinedDate.ToString("MMM yyyy")</small>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="col-md-2 text-end">
                            <div class="btn-group" role="group">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-arrow-left"></i> Back
                                </a>
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                            type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" 
                                               asp-controller="Ads" asp-action="Details" 
                                               asp-route-id="@Model.AdvertisementId">
                                                <i class="fas fa-external-link-alt me-2"></i>View Ad
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <button class="dropdown-item text-danger" onclick="deleteConversation()">
                                                <i class="fas fa-trash me-2"></i>Delete Conversation
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Container -->
        <div class="col-12">
            <div class="card shadow-sm chat-container">
                <!-- Messages Area -->
                <div class="card-body p-0 d-flex flex-column" style="height: 70vh;">
                    <!-- Messages List -->
                    <div id="messagesContainer" class="flex-grow-1 overflow-auto p-3" 
                         style="max-height: calc(70vh - 120px);">
                        
                        <!-- Loading indicator -->
                        <div id="loadingMessages" class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading messages...</span>
                            </div>
                            <p class="text-muted mt-2">Loading conversation...</p>
                        </div>

                        <!-- Messages will be loaded here via SignalR -->
                        <div id="messagesList">
                            @if (Model.Messages.Any())
                            {
                                @foreach (var message in Model.Messages)
                                {
                                    <div class="message-item @(message.IsFromCurrentUser ? "message-sent" : "message-received")" 
                                         data-message-id="@message.Id">
                                        <div class="message-bubble @message.MessageClasses p-3 rounded mb-2">
                                            @if (!string.IsNullOrEmpty(message.TypeDisplay))
                                            {
                                                <div class="message-type mb-2">
                                                    <span class="@message.TypeBadgeClass">@message.TypeDisplay</span>
                                                </div>
                                            }
                                            <div class="message-content">@message.Content</div>
                                            <div class="message-meta mt-2 small opacity-75">
                                                <span class="message-time">@message.ShortTimeFormat</span>
                                                @if (message.IsFromCurrentUser && message.IsRead)
                                                {
                                                    <i class="fas fa-check-double ms-2" title="Read"></i>
                                                }
                                                else if (message.IsFromCurrentUser)
                                                {
                                                    <i class="fas fa-check ms-2" title="Sent"></i>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fas fa-comments fa-3x text-muted mb-3"></i>
                                    <h6 class="text-muted">No messages yet</h6>
                                    <p class="text-muted">Start the conversation by sending a message below.</p>
                                </div>
                            }
                        </div>

                        <!-- Typing indicator -->
                        <div id="typingIndicator" class="typing-indicator" style="display: none;">
                            <div class="message-item message-received">
                                <div class="message-bubble bg-light p-3 rounded">
                                    <div class="typing-animation">
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                    </div>
                                    <small class="text-muted">
                                        <span id="typingUserName">@Model.OtherUserName</span> is typing...
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Message Input Area -->
                    <div class="border-top p-3">
                        <!-- Quick Message Templates -->
                        <div class="mb-3">
                            <div class="btn-group-sm" role="group">
                                @foreach (var template in ViewBag.MessageTemplates as List<SecondHandGoods.Web.Models.Chat.MessageTemplateViewModel>)
                                {
                                    <button type="button" 
                                            class="btn btn-outline-primary btn-sm me-2 mb-2 template-btn"
                                            data-template="@template.Content"
                                            data-type="@((int)template.MessageType)">
                                        <i class="@template.IconClass me-1"></i>@template.Title
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Message Form -->
                        <form id="messageForm">
                            <div class="input-group">
                                <textarea id="messageInput" 
                                          class="form-control" 
                                          placeholder="Type your message..."
                                          rows="2"
                                          maxlength="1000"
                                          style="resize: none;"></textarea>
                                <button type="submit" 
                                        class="btn btn-primary"
                                        id="sendButton">
                                    <i class="fas fa-paper-plane"></i>
                                </button>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <small class="text-muted">
                                    <span id="charCount">0</span>/1000 characters
                                </small>
                                <small class="text-muted">
                                    Press Ctrl+Enter to send
                                </small>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Connection Status -->
<div id="connectionStatus" class="position-fixed bottom-0 end-0 m-3" style="z-index: 1050;">
    <div class="alert alert-warning alert-dismissible fade show" role="alert" style="display: none;">
        <i class="fas fa-wifi me-2"></i>
        <span id="connectionMessage">Connecting...</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
</div>

<!-- Hidden form for fallback message sending -->
<form asp-action="SendMessage" method="post" id="fallbackMessageForm" style="display: none;">
    <input type="hidden" name="AdvertisementId" value="@Model.AdvertisementId" />
    <input type="hidden" name="ReceiverId" value="@Model.OtherUserId" />
    <input type="hidden" name="Content" id="fallbackContent" />
    <input type="hidden" name="MessageType" id="fallbackMessageType" value="1" />
</form>

<style>
    .chat-container {
        height: 70vh;
    }

    .message-item {
        margin-bottom: 15px;
    }

    .message-sent {
        text-align: right;
    }

    .message-sent .message-bubble {
        display: inline-block;
        max-width: 70%;
        margin-left: auto;
        background-color: #007bff !important;
        color: white !important;
    }

    .message-received .message-bubble {
        display: inline-block;
        max-width: 70%;
        background-color: #f8f9fa;
        color: #333;
    }

    .typing-indicator {
        animation: fadeIn 0.3s ease-in;
    }

    .typing-animation {
        display: inline-block;
    }

    .typing-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background-color: #999;
        border-radius: 50%;
        margin: 0 2px;
        animation: typing 1.4s infinite ease-in-out;
    }

    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes typing {
        0%, 80%, 100% { 
            transform: scale(0.8);
            opacity: 0.5;
        }
        40% { 
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    #messagesContainer {
        scroll-behavior: smooth;
    }

    .template-btn {
        font-size: 0.8rem;
    }

    .message-meta {
        font-size: 0.75rem;
    }
</style>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    
    <script>
        // SignalR connection setup
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();

        // Current conversation data
        const conversationData = {
            advertisementId: @Model.AdvertisementId,
            otherUserId: '@Model.OtherUserId',
            currentUserId: '@Model.CurrentUserId',
            conversationId: '@Model.ConversationId'
        };

        let isTyping = false;
        let typingTimeout = null;

        // DOM elements
        const messagesContainer = document.getElementById('messagesContainer');
        const messagesList = document.getElementById('messagesList');
        const loadingMessages = document.getElementById('loadingMessages');
        const messageInput = document.getElementById('messageInput');
        const messageForm = document.getElementById('messageForm');
        const sendButton = document.getElementById('sendButton');
        const typingIndicator = document.getElementById('typingIndicator');
        const charCount = document.getElementById('charCount');
        const connectionStatus = document.getElementById('connectionStatus');

        // Initialize chat
        document.addEventListener('DOMContentLoaded', function() {
            initializeChat();
            setupEventListeners();
            startConnection();
        });

        function initializeChat() {
            // Hide loading indicator if we have messages
            if (messagesList.children.length > 0) {
                loadingMessages.style.display = 'none';
                scrollToBottom();
            }

            // Setup character counter
            messageInput.addEventListener('input', function() {
                charCount.textContent = this.value.length;
                
                // Send typing indicator
                if (!isTyping && this.value.trim()) {
                    isTyping = true;
                    connection.invoke("SendTypingIndicator", conversationData.advertisementId, conversationData.otherUserId, true);
                }
                
                // Clear typing timeout
                if (typingTimeout) {
                    clearTimeout(typingTimeout);
                }
                
                // Set timeout to stop typing indicator
                typingTimeout = setTimeout(() => {
                    if (isTyping) {
                        isTyping = false;
                        connection.invoke("SendTypingIndicator", conversationData.advertisementId, conversationData.otherUserId, false);
                    }
                }, 3000);
            });

            // Setup template buttons
            document.querySelectorAll('.template-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const template = this.dataset.template;
                    messageInput.value = template;
                    messageInput.focus();
                    charCount.textContent = template.length;
                });
            });
        }

        function setupEventListeners() {
            // Message form submission
            messageForm.addEventListener('submit', function(e) {
                e.preventDefault();
                sendMessage();
            });

            // Keyboard shortcuts
            messageInput.addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.key === 'Enter') {
                    e.preventDefault();
                    sendMessage();
                }
                
                if (e.key === 'Enter' && !e.shiftKey && !e.ctrlKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });
        }

        async function startConnection() {
            try {
                showConnectionStatus('Connecting...', 'warning');
                await connection.start();
                console.log("Connected to chat hub");
                
                // Join the conversation
                await connection.invoke("JoinConversation", conversationData.advertisementId, conversationData.otherUserId);
                
                hideConnectionStatus();
                
            } catch (err) {
                console.error("Connection failed:", err);
                showConnectionStatus('Connection failed. Using fallback mode.', 'danger');
            }
        }

        // SignalR event handlers
        connection.on("ConversationJoined", function (conversationId, advertisementId) {
            console.log("Joined conversation:", conversationId);
            loadingMessages.style.display = 'none';
        });

        connection.on("LoadRecentMessages", function (messages, conversationId) {
            console.log("Loading recent messages:", messages.length);
            loadingMessages.style.display = 'none';
            
            if (messages && messages.length > 0) {
                // Clear existing messages and load new ones
                messagesList.innerHTML = '';
                messages.forEach(message => {
                    addMessageToUI(message);
                });
                scrollToBottom();
            }
        });

        connection.on("ReceiveMessage", function (message) {
            console.log("Received message:", message);
            const msgId = message.id !== undefined ? message.id : message.Id;
            if (msgId && document.querySelector(`[data-message-id="${msgId}"]`)) return;
            addMessageToUI(message);
            scrollToBottom();

            // Mark as read if it's for us and we're viewing the conversation (handle camelCase from SignalR JSON)
            if ((message.receiverId || message.ReceiverId) === conversationData.currentUserId) {
                const msgId = message.id !== undefined ? message.id : message.Id;
                setTimeout(() => {
                    connection.invoke("MarkMessagesAsRead", [msgId]);
                }, 1000);
            }
        });

        connection.on("TypingIndicator", function (indicator) {
            if (indicator.UserId !== conversationData.currentUserId) {
                if (indicator.IsTyping) {
                    document.getElementById('typingUserName').textContent = indicator.UserName;
                    typingIndicator.style.display = 'block';
                    scrollToBottom();
                } else {
                    typingIndicator.style.display = 'none';
                }
            }
        });

        connection.on("MessagesRead", function (messageIds, userId) {
            if (userId !== conversationData.currentUserId) {
                messageIds.forEach(messageId => {
                    const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
                    if (messageElement) {
                        const checkIcon = messageElement.querySelector('.fas.fa-check');
                        if (checkIcon) {
                            checkIcon.classList.remove('fa-check');
                            checkIcon.classList.add('fa-check-double');
                            checkIcon.title = 'Read';
                        }
                    }
                });
            }
        });

        connection.on("Error", function (error) {
            console.error("Hub error:", error);
            showConnectionStatus(error, 'danger');
        });

        // Connection state handlers
        connection.onclose(function() {
            showConnectionStatus('Connection lost. Attempting to reconnect...', 'warning');
            setTimeout(() => startConnection(), 3000);
        });

        function sendMessage() {
            const content = messageInput.value.trim();
            if (!content) return;

            // Disable send button temporarily
            sendButton.disabled = true;

            // Stop typing indicator
            if (isTyping) {
                isTyping = false;
                connection.invoke("SendTypingIndicator", conversationData.advertisementId, conversationData.otherUserId, false);
            }

            if (connection.state === signalR.HubConnectionState.Connected) {
                // Send via SignalR
                connection.invoke("SendMessage", conversationData.advertisementId, conversationData.otherUserId, content)
                    .catch(err => {
                        console.error("Error sending message:", err);
                        // Fallback to HTTP POST
                        sendMessageFallback(content);
                    });
            } else {
                // Fallback to HTTP POST
                sendMessageFallback(content);
            }

            // Clear input
            messageInput.value = '';
            charCount.textContent = '0';
            
            // Re-enable send button
            setTimeout(() => {
                sendButton.disabled = false;
                messageInput.focus();
            }, 1000);
        }

        function sendMessageFallback(content) {
            document.getElementById('fallbackContent').value = content;
            document.getElementById('fallbackMessageForm').submit();
        }

        function addMessageToUI(message) {
            const senderId = message.senderId || message.SenderId;
            const isFromCurrentUser = senderId === conversationData.currentUserId;
            const isRead = message.isRead !== undefined ? message.isRead : message.IsRead;
            const messageId = message.id !== undefined ? message.id : message.Id;
            const content = message.content !== undefined ? message.content : message.Content;
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message-item ${isFromCurrentUser ? 'message-sent' : 'message-received'}`;
            messageDiv.setAttribute('data-message-id', messageId);

            const bubbleClass = isFromCurrentUser 
                ? 'message-bubble bg-primary text-white p-3 rounded mb-2'
                : 'message-bubble bg-light p-3 rounded mb-2';

            const readIcon = isFromCurrentUser 
                ? (isRead ? '<i class="fas fa-check-double ms-2" title="Read"></i>' : '<i class="fas fa-check ms-2" title="Sent"></i>')
                : '';

            const timeDisplay = (message.sentAtDisplay || message.SentAtDisplay) || formatMessageTime(message.sentAt || message.SentAt);
            messageDiv.innerHTML = `
                <div class="${bubbleClass}">
                    <div class="message-content">${escapeHtml(content)}</div>
                    <div class="message-meta mt-2 small opacity-75">
                        <span class="message-time">${escapeHtml(timeDisplay)}</span>
                        ${readIcon}
                    </div>
                </div>
            `;

            messagesList.appendChild(messageDiv);
        }

        function scrollToBottom() {
            setTimeout(() => {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 100);
        }

        function showConnectionStatus(message, type) {
            const statusElement = connectionStatus.querySelector('.alert');
            const messageElement = document.getElementById('connectionMessage');
            
            statusElement.className = `alert alert-${type} alert-dismissible fade show`;
            messageElement.textContent = message;
            statusElement.style.display = 'block';
        }

        function hideConnectionStatus() {
            const statusElement = connectionStatus.querySelector('.alert');
            statusElement.style.display = 'none';
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function formatMessageTime(timestamp) {
            try {
                if (timestamp == null || timestamp === '' || timestamp === undefined) return 'Just now';
                if (typeof timestamp === 'string' && timestamp.toLowerCase() === 'invalid date') return 'Just now';
                if (typeof timestamp === 'object' && !(timestamp instanceof Date)) return 'Just now';
                // Normalize: .NET ISO can have 7 fractional seconds (e.g. .0000000Z) which some browsers reject
                let normalized = timestamp;
                if (typeof normalized === 'string' && /\.\d+Z$/i.test(normalized)) {
                    normalized = normalized.replace(/(\.\d{3})\d*Z$/i, '$1Z');
                }
                if (typeof normalized === 'number' && normalized < 1e12) {
                    normalized = normalized * 1000; // assume seconds if small
                }
                const date = new Date(normalized);
                if (isNaN(date.getTime())) return 'Just now';
                const now = new Date();
                const diff = now - date;

                if (diff < 60000) return 'Just now';
                if (diff < 3600000) return `${Math.floor(diff / 60000)}m ago`;
                let result;
                if (diff < 86400000) {
                    result = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                } else {
                    result = date.toLocaleDateString();
                }
                if (!result || result.toLowerCase().indexOf('invalid') !== -1) return 'Just now';
                return result;
            } catch (e) {
                return 'Just now';
            }
        }

        function deleteConversation() {
            if (confirm('Are you sure you want to delete this conversation? This action cannot be undone.')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteConversation")';
                
                const advertisementIdInput = document.createElement('input');
                advertisementIdInput.type = 'hidden';
                advertisementIdInput.name = 'advertisementId';
                advertisementIdInput.value = conversationData.advertisementId;
                
                const otherUserIdInput = document.createElement('input');
                otherUserIdInput.type = 'hidden';
                otherUserIdInput.name = 'otherUserId';
                otherUserIdInput.value = conversationData.otherUserId;
                
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                
                form.appendChild(advertisementIdInput);
                form.appendChild(otherUserIdInput);
                form.appendChild(tokenInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Clean up on page unload
        window.addEventListener('beforeunload', function() {
            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("LeaveConversation", conversationData.advertisementId, conversationData.otherUserId);
            }
        });
    </script>
}