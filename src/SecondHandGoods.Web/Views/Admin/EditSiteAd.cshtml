@model SecondHandGoods.Web.Models.Admin.SiteAdEditViewModel
@{
    ViewData["Title"] = "Edit Site Ad";
    ViewData["ShowAdminNavigation"] = true;
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-stretch align-items-md-center gap-3">
            <div>
                <h1 class="h3 mb-0 text-primary">
                    <i class="fas fa-edit me-2"></i>Edit Site Ad — @Model.SlotKey
                </h1>
                <p class="text-muted mb-0">Update image, link and visibility for this footer ad slot</p>
            </div>
            <a asp-action="SiteAds" class="btn btn-outline-primary w-100 w-md-auto align-self-md-center">
                <i class="fas fa-arrow-left me-1"></i>Back to Site Ads
            </a>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h5 class="card-title mb-0">
                    <i class="fas fa-cog me-2"></i>Ad configuration
                </h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="EditSiteAd">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SlotKey" />
                    <input type="hidden" asp-for="DisplayOrder" />

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label"></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/banner.png or leave empty for placeholder" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <div class="form-text">Full URL to the ad image. Leave empty to show "Ad space" placeholder.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TargetUrl" class="form-label"></label>
                        <input asp-for="TargetUrl" class="form-control" placeholder="https://advertiser.com" />
                        <span asp-validation-for="TargetUrl" class="text-danger"></span>
                        <div class="form-text">Where users go when they click the ad.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AltText" class="form-label"></label>
                        <input asp-for="AltText" class="form-control" placeholder="Advertisement" />
                        <span asp-validation-for="AltText" class="text-danger"></span>
                        <div class="form-text">Accessibility text for the image.</div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                        <div class="form-text">Inactive slots still show a placeholder in the footer.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Save changes
                        </button>
                        <a asp-action="SiteAds" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
