@model List<SecondHandGoods.Web.Models.Admin.SiteAdItemViewModel>
@{
    ViewData["Title"] = "Site Ads";
    ViewData["ShowAdminNavigation"] = true;
}

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 text-primary">
                    <i class="fas fa-ad me-2"></i>Site Ads
                </h1>
                <p class="text-muted mb-0">Manage paid advertisement slots in the footer (footer-1, footer-2, footer-3)</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h5 class="card-title mb-0">
                    <i class="fas fa-th-large me-2"></i>Footer ad slots
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Slot</th>
                                    <th>Preview</th>
                                    <th>Image URL</th>
                                    <th>Link URL</th>
                                    <th>Active</th>
                                    <th style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ad in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@ad.SlotKey</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(ad.ImageUrl))
                                            {
                                                <img src="@ad.ImageUrl" alt="@(ad.AltText ?? "Ad")" class="img-thumbnail" style="max-height: 50px; max-width: 120px; object-fit: contain;" />
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Placeholder</span>
                                            }
                                        </td>
                                        <td class="small text-break">@(string.IsNullOrWhiteSpace(ad.ImageUrl) ? "—" : (ad.ImageUrl.Length > 40 ? ad.ImageUrl.Substring(0, 40) + "…" : ad.ImageUrl))</td>
                                        <td class="small text-break">@(string.IsNullOrWhiteSpace(ad.TargetUrl) ? "—" : (ad.TargetUrl.Length > 40 ? ad.TargetUrl.Substring(0, 40) + "…" : ad.TargetUrl))</td>
                                        <td>
                                            @if (ad.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="EditSiteAd" asp-route-id="@ad.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit me-1"></i>Edit
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-ad fa-3x mb-3"></i>
                        <p class="mb-0">No site ad slots found. They are created automatically on first run.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
