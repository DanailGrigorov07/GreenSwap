@{
    ViewData["Title"] = "Something went wrong";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div class="mb-4">
                <span class="display-1 fw-bold text-muted">500</span>
            </div>
            <h1 class="h2 mb-3">Something went wrong</h1>
            <p class="text-muted mb-4">
                We're sorry, but something went wrong on our end. Please try again in a moment, or go back to the homepage.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="fas fa-home me-2"></i>Back to Home
            </a>
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-muted">Try again</a>
            </div>
        </div>
    </div>
</div>
