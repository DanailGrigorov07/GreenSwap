@{
    var statusCode = ViewData["StatusCode"] as int? ?? 0;
    ViewData["Title"] = statusCode > 0 ? $"Error {statusCode}" : "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            @if (statusCode > 0)
            {
                <div class="mb-4">
                    <span class="display-1 fw-bold text-muted">@statusCode</span>
                </div>
            }
            <h1 class="h2 mb-3">An error occurred</h1>
            <p class="text-muted mb-4">
                Something went wrong while processing your request. Please try again or return to the homepage.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="fas fa-home me-2"></i>Back to Home
            </a>
        </div>
    </div>
</div>
